service:billing-api
    a kg:Service ;
    kg:name "Billing API" ;
    kg:ownedBy team:data-platform ;
    kg:partOfDomain domain:finance ;
    kg:deployedIn environment:prod ;
    kg:hasRuntime runtime:java-21 ;
    kg:runsOn infra:server-a ;
    kg:readsFrom infra:postgres-prod ;
    kg:writesTo infra:postgres-prod ;
    kg:usesCache infra:redis-prod ;
    kg:dependsOn infra:postgres-prod ;
    kg:dependsOn infra:redis-prod ;
    kg:publishesTo infra:billing-events ;
    kg:emitsTelemetryTo infra:observability-events ;
    kg:consumesFrom infra:billing-command-queue ;
    kg:exposesEndpoint endpoint:billing-api ;
    kg:monitoredBy monitor:billing-api-slo-monitor ;
    kg:shownOn dashboard:finance-ops-dashboard ;
    kg:coveredByPolicy policy:pci-dss-payment-data ;
    kg:monthlyCostUSD "420.5"^^xsd:decimal ;
    kg:criticality "critical" ;
    kg:tier "tier-1" ;
    kg:sloAvailability "99.95"^^xsd:decimal ;
    kg:dependsOn service:payment-api .

endpoint:billing-api
    a kg:Endpoint ;
    kg:name "Billing API Endpoint" ;
    kg:httpMethod "GET" ;
    kg:path "/v1/billing" ;
    kg:exposedBy gateway:internal-api-gateway .

