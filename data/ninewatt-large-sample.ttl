<>
    a owl:Ontology ;
    rdfs:label "Ninewatt large sample knowledge graph" ;
    kg:name "Ninewatt Large Sample Knowledge Graph" .

kg:KnowledgeAsset
    a owl:Class ;
    rdfs:label "Knowledge Asset" .

